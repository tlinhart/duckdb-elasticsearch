physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*employee\.name>='R'.*

# --- LIKE on text field with .keyword in struct ---
# Note: DuckDB may not push LIKE on nested struct fields - handled by FILTER node
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE employee.name LIKE 'Robert%';
----
1

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE employee.name LIKE 'Robert%';
----
physical_plan	<REGEX>:.*FILTER.*ELASTICSEARCH_QUERY.*

# ==============================================================================
