# --- LIKE prefix on keyword field (email) ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE email LIKE 'alice%';
