# name: test/sql/filter_pushdown.test
# description: Test SQL filter translation to Elasticsearch Query DSL
# group: [sql]

# This test file verifies which filters are pushed down to Elasticsearch and which
# are handled by DuckDB. It covers all field types and operators.
#
# Test Index Schema:
# - name: text WITH .keyword subfield
# - email: keyword
# - description: text WITHOUT .keyword subfield
# - colors: keyword (array)
# - amount: integer
# - price: float
# - deprecated: boolean
# - birth_date: date
# - employee.name: text WITH .keyword subfield (nested struct)
# - employee.salary: double (nested struct)
# - users.name: text WITHOUT .keyword (nested array)
# - users.email: keyword (nested array)
#
# Pushdown Behavior Summary:
# +------------------+----------+----------+----------+----------+----------+----------+
# | Field Type       | =, !=    | <, >, <= | IN       | LIKE     | ILIKE    | IS NULL  |
# +------------------+----------+----------+----------+----------+----------+----------+
# | keyword          | PUSHED   | PUSHED   | PUSHED   | PUSHED   | PUSHED   | PUSHED   |
# | text + .keyword  | PUSHED   | PUSHED   | PUSHED   | PUSHED   | PUSHED   | PUSHED   |
# | text (no .kw)    | ERROR    | ERROR    | ERROR    | ERROR    | ERROR    | PUSHED   |
# | integer/float    | PUSHED   | PUSHED   | PUSHED   | N/A      | N/A      | PUSHED   |
# | boolean          | PUSHED   | N/A      | PUSHED   | N/A      | N/A      | PUSHED   |
# | date             | PUSHED   | PUSHED   | PUSHED   | N/A      | N/A      | PUSHED   |
# +------------------+----------+----------+----------+----------+----------+----------+
#
# Legend:
# - PUSHED: Filter is translated to Elasticsearch Query DSL
# - ERROR: Throws error with suggestions (add .keyword, use MATERIALIZED CTE, or use query param)
# - FILTER: Filter cannot be pushed at all (volatile, multi-column, function on column)
# - N/A: Not applicable for this field type

require elasticsearch

require-env ELASTICSEARCH_TEST_SERVER_AVAILABLE

# ==============================================================================
# SECTION 1: NUMERIC FIELDS (integer, float, double)
# All operators are PUSHED to Elasticsearch
# ==============================================================================

# --- Equality ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount = 42;
----
1

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount = 42;
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount=42.*

# --- Inequality ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount != 42;
----
9

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount != 42;
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount!=42.*

# --- Greater Than ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount > 50;
----
5

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount > 50;
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount>50.*

# --- Less Than or Equal ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount <= 30;
----
3

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount <= 30;
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount<=30.*

# --- IN clause ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount IN (42, 87, 15);
----
3

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount IN (42, 87, 15);
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount IN \(42, 87, 15\).*

# --- Range (BETWEEN equivalent) ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE amount >= 30 AND amount <= 70;
----
4

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE amount >= 30 AND amount <= 70;
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*amount>=30 AND amount<=70.*

