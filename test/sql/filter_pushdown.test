# --- ILIKE on keyword field ---
query I
SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE email ILIKE 'ALICE%';
----
1

query II
EXPLAIN SELECT COUNT(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
) WHERE email ILIKE 'ALICE%';
----
physical_plan	<REGEX>:.*ELASTICSEARCH_QUERY.*Filters:.*email ~~\* 'ALICE%'.*

