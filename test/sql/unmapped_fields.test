# name: test/sql/unmapped_fields.test
# description: Test unmapped fields captured in the _unmapped_ VARIANT column
# group: [sql]

require elasticsearch

require-env ELASTICSEARCH_TEST_SERVER_AVAILABLE

# Verify documents with unmapped fields are detected.
# Documents 2, 5 and 8 have the 'extra' field which is not in the mapping.
query I
SELECT count(*) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _unmapped_ IS NOT NULL;
----
3

# Test selecting _unmapped_ column.
query I
SELECT _unmapped_ FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _id IN ('2', '5', '8')
ORDER BY _id;
----
{'extra': 10}
{'extra': [one, two, three]}
{'extra': {'note': This is a note, 'value': 20.3}}

# Verify _unmapped_ column has a VARIANT type.
query I
SELECT typeof(_unmapped_) FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _id = '2';
----
VARIANT

# Test document without unmapped fields returns NULL in the _unmapped_ column.
query I
SELECT _unmapped_ FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _id = '1';
----
NULL

# Test extracting nested data from the _unmapped_ column using dot notation.
query I
SELECT _unmapped_.extra.note FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _id = '8';
----
This is a note

# Test extracting nested data from the _unmapped_ column using variant_extract.
query I
SELECT variant_extract(_unmapped_, 'extra') FROM elasticsearch_query(
    host := 'localhost',
    index := 'test',
    username := 'elastic',
    password := 'test'
)
WHERE _id = '2';
----
10
